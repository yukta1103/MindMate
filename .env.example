# MindMate Environment Configuration

# OpenAI API Configuration (Optional - for better responses)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model Selection (default: gpt-4o-mini)
# Options: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Note: The application will work without OpenAI using a fallback template-based mode
# To use fallback mode, simply don't create a .env file or leave OPENAI_API_KEY empty
